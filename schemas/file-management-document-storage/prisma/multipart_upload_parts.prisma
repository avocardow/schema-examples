// multipart_upload_parts: Individual parts of a multipart upload, assembled into the final file on completion.
// See README.md for full design rationale.

model MultipartUploadPart {
  id          String   @id @default(uuid())
  uploadId    String   @map("upload_id")

  partNumber  Int      @map("part_number") // 1-based ordering. Parts are assembled in part_number order.

  size        BigInt   @map("size") // This part's size in bytes.

  checksum    String?  @map("checksum") // Per-part integrity hash (e.g., MD5, CRC32).

  storageKey  String   @map("storage_key") // Temporary storage location for this part.

  createdAt   DateTime @default(now()) @map("created_at")

  upload      MultipartUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([uploadId, partNumber])
  @@map("multipart_upload_parts")
}
