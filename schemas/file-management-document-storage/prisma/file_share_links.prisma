// file_share_links: URL-based sharing with optional password protection, expiry, and download tracking.
// See README.md for full design rationale.

enum FileShareLinkTargetType {
  file
  folder
}

enum FileShareLinkScope {
  anyone
  organization
  specific_users
}

enum FileShareLinkPermission {
  view
  download
  edit
  upload
}

model FileShareLink {
  id             String                    @id @default(uuid())
  targetType     FileShareLinkTargetType   @map("target_type")
  targetFileId   String?                   @map("target_file_id")
  targetFolderId String?                   @map("target_folder_id")
  createdBy      String                    @map("created_by")
  token          String                    @unique // URL-safe token for the share link.
  scope          FileShareLinkScope        @default(anyone)
  permission     FileShareLinkPermission   @default(view)
  passwordHash   String?                   @map("password_hash") // Hashed — never store plaintext.
  expiresAt      DateTime?                 @map("expires_at") // Null = never expires.
  maxDownloads   Int?                      @map("max_downloads") // Null = unlimited.
  downloadCount  Int                       @default(0) @map("download_count")
  name           String? // Human-readable name (e.g., "Client review link").
  isActive       Boolean                   @default(true) @map("is_active")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @default(now()) @updatedAt @map("updated_at")

  targetFile   File?   @relation(fields: [targetFileId], references: [id], onDelete: Cascade)
  targetFolder Folder? @relation(fields: [targetFolderId], references: [id], onDelete: Cascade)
  creator      User    @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([targetType, targetFileId])
  @@index([targetType, targetFolderId])
  @@index([createdBy])
  @@index([expiresAt])
  @@map("file_share_links")
}
