// folder_permissions: Per-user permission grants on folders, with optional inheritance tracking.
// See README.md for full design rationale.

enum FolderPermissionLevel {
  view
  edit
  manage
}

model FolderPermission {
  id         String                @id @default(uuid())
  folderId   String                @map("folder_id")
  userId     String                @map("user_id")
  permission FolderPermissionLevel @default(view)
  inherited  Boolean               @default(false)
  grantedBy  String?               @map("granted_by")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @default(now()) @updatedAt @map("updated_at")

  folder  Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user    User   @relation("FolderPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  granter User?  @relation("FolderPermissionGranter", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([folderId, userId])
  @@index([userId])
  @@index([folderId])
  @@map("folder_permissions")
}
