// file_comments: Threaded comments on files — supports nested replies via parentId self-reference and resolved state for review workflows.
// See README.md for full design rationale.

model FileComment {
  id          String    @id @default(uuid())
  fileId      String    @map("file_id")
  parentId    String?   @map("parent_id") // Null = top-level comment.
  authorId    String    @map("author_id") // Who wrote this comment.
  body        String                      // Comment text. Supports plain text or markdown.
  isResolved  Boolean   @default(false) @map("is_resolved") // Whether this comment thread is resolved.
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") // Comments can be edited.

  file        File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  parent      FileComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     FileComment[] @relation("CommentReplies")
  author      User         @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([fileId, createdAt])
  @@index([parentId])
  @@index([authorId])
  @@map("file_comments")
}
