// kb_categories: Hierarchical sections organizing knowledge base articles for self-service.
// See README.md for full design rationale and field documentation.

model KbCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?  @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  parent   KbCategory?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children KbCategory[] @relation("CategoryParent")

  articles KbArticle[]

  @@index([parentId, sortOrder])
  @@map("kb_categories")
}
