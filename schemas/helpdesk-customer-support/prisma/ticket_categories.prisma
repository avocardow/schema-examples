// ticket_categories: Hierarchical topic tree for classifying and routing tickets.
// See README.md for full design rationale and field documentation.

model TicketCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?  @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  parent   TicketCategory?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children TicketCategory[] @relation("CategoryParent")

  tickets Ticket[]

  @@index([parentId, sortOrder])
  @@map("ticket_categories")
}
