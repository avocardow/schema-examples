// sla_policies: Service-level agreements defining response and resolution time commitments.
// See README.md for full design rationale and field documentation.

model SlaPolicy {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  scheduleId  String?  @map("schedule_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  schedule BusinessSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  slaPolicyTargets SlaPolicyTarget[]
  tickets          Ticket[]          @relation("TicketSlaPolicy")

  @@index([isActive, sortOrder])
  @@map("sla_policies")
}
