// referrals: Tracks visitor referrals from affiliates through the conversion funnel.
// See README.md for full design rationale.

enum ReferralStatus {
  VISIT
  LEAD
  CONVERTED
  EXPIRED
}

model Referral {
  id          String         @id @default(uuid())
  affiliateId String         @map("affiliate_id")
  clickId     String?        @map("click_id")
  visitorId   String?        @map("visitor_id")
  email       String?
  status      ReferralStatus @default(VISIT)
  landingUrl  String?        @map("landing_url")
  metadata    Json?
  convertedAt DateTime?      @map("converted_at")
  expiresAt   DateTime?      @map("expires_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @default(now()) @map("updated_at")

  affiliate   Affiliate      @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  click       Click?         @relation(fields: [clickId], references: [id], onDelete: SetNull)
  conversions Conversion[]

  @@index([affiliateId, status])
  @@index([status])
  @@index([email])
  @@index([visitorId])
  @@map("referrals")
}
