// items: Auction items listed by sellers with condition grading and category classification.
// See README.md for full design rationale.

enum ItemCondition {
  NEW
  LIKE_NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
}

model Item {
  id             String         @id @default(uuid())
  sellerId       String         @map("seller_id")
  categoryId     String?        @map("category_id")
  title          String
  description    String?
  condition      ItemCondition  @default(NEW)
  conditionNotes String?        @map("condition_notes")
  metadata       Json?          @default("{}")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")

  seller         User           @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  category       Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images         ItemImage[]
  auctions       Auction[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([condition])
  @@map("items")
}
