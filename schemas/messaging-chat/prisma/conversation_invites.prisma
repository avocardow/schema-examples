// conversation_invites: Pending invitations to join private conversations.
// See README.md for full design rationale.

enum ConversationInviteStatus {
  pending
  accepted
  declined
  expired
}

model ConversationInvite {
  id             String                   @id @default(uuid())
  conversationId String                   @map("conversation_id")
  inviterId      String                   @map("inviter_id")
  inviteeId      String                   @map("invitee_id")
  status         ConversationInviteStatus @default(pending) @map("status")
  message        String?                  @map("message")
  expiresAt      DateTime?                @map("expires_at")
  respondedAt    DateTime?                @map("responded_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @default(now()) @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("InviteSender", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee      User         @relation("InviteReceiver", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([conversationId, inviteeId, status])
  @@index([inviteeId, status])
  @@index([conversationId, status])
  @@index([expiresAt])
  @@map("conversation_invites")
}
