// usage_summaries: Aggregated feature usage per organization and billing period for reporting and invoicing.
// See README.md for full design rationale and field documentation.

model UsageSummary {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  featureId      String   @map("feature_id")
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  totalQuantity  BigInt   @default(0) @map("total_quantity")
  eventCount     Int      @default(0) @map("event_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  feature      Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([organizationId, featureId, periodStart])
  @@index([periodStart, periodEnd])
  @@map("usage_summaries")
}
