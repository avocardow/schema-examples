// custom_domains: Custom domain mappings for organizations with verification and SSL tracking.
// See README.md for full design rationale and field documentation.

enum VerificationMethod {
  cname
  txt
}

enum SslStatus {
  pending
  active
  failed
  expired
}

model CustomDomain {
  id                 String              @id @default(uuid())
  organizationId     String              @map("organization_id")
  domain             String              @unique
  verificationMethod VerificationMethod  @default(cname) @map("verification_method")
  verificationToken  String              @map("verification_token")
  isVerified         Boolean             @default(false) @map("is_verified")
  verifiedAt         DateTime?           @map("verified_at")
  sslStatus          SslStatus           @default(pending) @map("ssl_status")
  sslExpiresAt       DateTime?           @map("ssl_expires_at")
  isPrimary          Boolean             @default(false) @map("is_primary")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("custom_domains")
}
