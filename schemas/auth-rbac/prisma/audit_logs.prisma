// audit_logs: Immutable event log for security-relevant actions.
// Append-only -- never update or delete rows.
// Uses polymorphic actor/target (not FKs) so logs survive entity deletion.
// See README.md for full design rationale and field documentation.

enum AuditActorType {
  user
  system
  api_key
  service
}

model AuditLog {
  id              String          @id @default(uuid())

  // Structured event codes: resource.action.result
  // e.g., "user.login.success", "role.assigned", "session.impersonation.started"
  eventType       String          @map("event_type")

  // Polymorphic actor/target: NOT FKs. Audit logs must survive entity deletion.
  actorType       AuditActorType  @map("actor_type")
  actorId         String?         @map("actor_id") // user_id, api_key_id, or service name.
  targetType      String?         @map("target_type") // e.g., "user", "organization", "role".
  targetId        String?         @map("target_id")

  organizationId  String?         @map("organization_id") // Survives org deletion (SET NULL, not CASCADE).
  ipAddress       String?         @map("ip_address")
  userAgent       String?         @map("user_agent")
  metadata        Json? // Event-specific details (e.g., {"old_role": "member", "new_role": "admin"}).
  createdAt       DateTime        @default(now()) @map("created_at") // Immutable. Audit logs are append-only.

  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([actorType, actorId])
  @@index([targetType, targetId])
  @@index([organizationId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}
