// sessions: Active login sessions. Tracks *how* the user authenticated, not just *that* they did.
// See README.md for full design rationale and field documentation.

enum AalLevel {
  aal1
  aal2
  aal3
}

model Session {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  tokenHash       String    @unique @map("token_hash") // SHA-256 hash. Never store raw session tokens.

  // Authentication Assurance Level: aal1 = password/OAuth, aal2 = MFA verified, aal3 = hardware key.
  aal             AalLevel  @default(aal1)

  mfaFactorId     String?   @map("mfa_factor_id")
  ipAddress       String?   @map("ip_address")
  userAgent       String?   @map("user_agent")
  countryCode     String?   @map("country_code") // ISO 3166-1 alpha-2, derived from IP.

  organizationId  String?   @map("organization_id") // Active org context for multi-tenant apps.
  impersonatorId  String?   @map("impersonator_id") // Set when an admin is impersonating this user.

  tag             String? // Custom label (e.g., "mobile", "api").
  lastActiveAt    DateTime? @map("last_active_at")
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User          @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  mfaFactor       MfaFactor?    @relation(fields: [mfaFactorId], references: [id], onDelete: SetNull)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  impersonator    User?         @relation("ImpersonatorSessions", fields: [impersonatorId], references: [id], onDelete: SetNull)
  refreshTokens   RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}
