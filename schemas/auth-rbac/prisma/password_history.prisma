// password_history: Previous password hashes for enterprise reuse-prevention policies.
// See README.md for full design rationale and field documentation.

model PasswordHistory {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  passwordHash  String   @map("password_hash") // The previous password hash. Compared against new passwords to prevent reuse.
  createdAt     DateTime @default(now()) @map("created_at") // When this password was set (not when it was retired).

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_history")
}
