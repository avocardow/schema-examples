// oauth_clients: For when your app acts as an OAuth server issuing tokens to third-party apps.
// See README.md for full design rationale and field documentation.

model OauthClient {
  id              String    @id @default(uuid()) // Also serves as the client_id in OAuth flows.
  name            String // Display name shown in the consent screen.
  secretHash      String    @map("secret_hash") // Hashed client secret. Never store plaintext.
  redirectUris    String[]  @map("redirect_uris") // Allowed redirect URIs. Strictly validated during authorization.
  grantTypes      String[]  @default([]) @map("grant_types") // e.g., ["authorization_code", "client_credentials"].
  scopes          String[]  @default([]) // Allowed scopes this client can request.

  appType         String?   @map("app_type") // "web", "spa", "native", or "m2m".

  organizationId  String?   @map("organization_id") // Which org owns this client. Null = platform-level.
  isFirstParty    Boolean   @default(false) @map("is_first_party") // First-party clients skip the consent screen.
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  authorizationCodes OauthAuthorizationCode[]

  @@index([organizationId])
  @@map("oauth_clients")
}
