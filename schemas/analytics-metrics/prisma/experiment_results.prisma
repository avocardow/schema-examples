// experiment_results: Statistical results per variant and metric with significance testing.
// See README.md for full design rationale.

model ExperimentResult {
  id            String            @id @default(uuid())
  experimentId  String            @map("experiment_id")
  variantId     String            @map("variant_id")
  metricId      String            @map("metric_id")
  sampleSize    BigInt            @default(0) @map("sample_size")
  meanValue     Decimal?          @map("mean_value")
  stddev        Decimal?
  ciLower       Decimal?          @map("ci_lower")
  ciUpper       Decimal?          @map("ci_upper")
  pValue        Decimal?          @map("p_value")
  lift          Decimal?
  isSignificant Boolean           @default(false) @map("is_significant")
  computedAt    DateTime          @map("computed_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")

  experiment    Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant       ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  metric        MetricDefinition  @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@unique([experimentId, variantId, metricId])
  @@map("experiment_results")
}
