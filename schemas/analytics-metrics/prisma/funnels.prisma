// funnels: Multi-step conversion funnels with configurable time windows.
// See README.md for full design rationale.

model Funnel {
  id               String   @id @default(uuid())
  name             String
  description      String?
  conversionWindow Int      @default(86400) @map("conversion_window")
  isActive         Boolean  @default(true) @map("is_active")
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  creator          User     @relation("FunnelCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  steps            FunnelStep[]

  @@index([isActive])
  @@index([createdBy])
  @@map("funnels")
}
