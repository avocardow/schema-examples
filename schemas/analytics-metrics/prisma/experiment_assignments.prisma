// experiment_assignments: User-to-variant assignments for experiment participation tracking.
// See README.md for full design rationale.

model ExperimentAssignment {
  id           String            @id @default(uuid())
  experimentId String            @map("experiment_id")
  variantId    String            @map("variant_id")
  userId       String?           @map("user_id")
  anonymousId  String?           @map("anonymous_id")
  assignedAt   DateTime          @map("assigned_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  experiment   Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant      ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  user         User?             @relation("ExperimentAssignmentUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([experimentId, userId])
  @@index([experimentId, variantId])
  @@index([userId])
  @@index([assignedAt])
  @@map("experiment_assignments")
}
