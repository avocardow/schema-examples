// page_views: Individual page view records with viewport and duration data.
// See README.md for full design rationale.

model PageView {
  id             String    @id @default(uuid())
  eventId        String?   @map("event_id")
  userId         String?   @map("user_id")
  anonymousId    String?   @map("anonymous_id")
  sessionId      String?   @map("session_id")
  url            String
  path           String
  title          String?
  referrer       String?
  hostname       String
  viewportWidth  Int?      @map("viewport_width")
  viewportHeight Int?      @map("viewport_height")
  screenWidth    Int?      @map("screen_width")
  screenHeight   Int?      @map("screen_height")
  duration       Int?
  timestamp      DateTime
  createdAt      DateTime  @default(now()) @map("created_at")

  event          Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user           User?     @relation("PageViewUser", fields: [userId], references: [id], onDelete: SetNull)
  session        Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([path])
  @@index([hostname, path])
  @@index([timestamp])
  @@index([anonymousId])
  @@map("page_views")
}
