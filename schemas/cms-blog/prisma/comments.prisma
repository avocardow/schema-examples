// comments: Threaded discussion system with moderation workflow and anonymous author support.
// See README.md for full design rationale.

enum CommentStatus {
  pending
  approved
  rejected
  spam
}

model Comment {
  id          String        @id @default(uuid())
  postId      String        @map("post_id")
  parentId    String?       @map("parent_id")
  authorId    String?       @map("author_id")
  authorName  String        @map("author_name")
  authorEmail String?       @map("author_email")
  content     String
  status      CommentStatus @default(pending)
  ipAddress   String?       @map("ip_address")
  userAgent   String?       @map("user_agent")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @map("updated_at")

  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent      Comment?      @relation("CommentParent", fields: [parentId], references: [id], onDelete: Cascade)
  children    Comment[]     @relation("CommentParent")
  author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  commentVotes CommentVote[]

  @@index([postId, status, createdAt])
  @@index([parentId])
  @@index([authorId])
  @@map("comments")
}
