// mutes: Temporary or permanent mutes of other users with optional expiration.
// See README.md for full design rationale.

model Mute {
  id        String    @id @default(uuid())
  muterId   String    @map("muter_id")
  mutedId   String    @map("muted_id")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  muter User @relation("MuteMuter", fields: [muterId], references: [id], onDelete: Cascade)
  muted User @relation("MuteMuted", fields: [mutedId], references: [id], onDelete: Cascade)

  @@unique([muterId, mutedId])
  @@index([mutedId])
  @@index([expiresAt])
  @@map("mutes")
}
