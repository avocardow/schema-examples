// follow_requests: Pending follow requests for private accounts with approval workflow.
// See README.md for full design rationale.

enum FollowRequestStatus {
  pending
  approved
  rejected
}

model FollowRequest {
  id          String              @id @default(uuid())
  requesterId String              @map("requester_id")
  targetId    String              @map("target_id")
  status      FollowRequestStatus @default(pending) @map("status")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @default(now()) @map("updated_at")

  requester User @relation("FollowRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("FollowRequestTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId, status])
  @@map("follow_requests")
}
