// posts: User-created posts with threading, quoting, and visibility controls.
// See README.md for full design rationale.

enum PostContentType {
  text
  system
  deleted
}

enum PostVisibility {
  public
  unlisted
  followers_only
  mentioned_only
}

model Post {
  id            String         @id @default(uuid())
  authorId      String         @map("author_id")
  content       String?        @map("content")
  contentType   PostContentType @default(text) @map("content_type")
  replyToId     String?        @map("reply_to_id")
  conversationId String?       @map("conversation_id")
  quoteOfId     String?        @map("quote_of_id")
  visibility    PostVisibility @default(public) @map("visibility")
  isEdited      Boolean        @default(false) @map("is_edited")
  editedAt      DateTime?      @map("edited_at")
  expiresAt     DateTime?      @map("expires_at")
  replyCount    Int            @default(0) @map("reply_count")
  reactionCount Int            @default(0) @map("reaction_count")
  repostCount   Int            @default(0) @map("repost_count")
  pollId        String?        @map("poll_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @map("updated_at")

  author           User       @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replyTo          Post?      @relation("PostReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies          Post[]     @relation("PostReply")
  conversation     Post?      @relation("PostConversation", fields: [conversationId], references: [id], onDelete: SetNull)
  threadPosts      Post[]     @relation("PostConversation")
  quoteOf          Post?      @relation("PostQuote", fields: [quoteOfId], references: [id], onDelete: SetNull)
  quotes           Post[]     @relation("PostQuote")
  poll             Poll?      @relation(fields: [pollId], references: [id], onDelete: SetNull)
  media            PostMedia[]
  reactions        Reaction[]
  reposts          Repost[]
  bookmarks        Bookmark[]
  postHashtags     PostHashtag[]
  mentions         Mention[]
  reports          PostReport[]

  @@index([authorId, createdAt])
  @@index([replyToId])
  @@index([conversationId, createdAt])
  @@index([visibility, createdAt])
  @@index([expiresAt])
  @@index([quoteOfId])
  @@map("posts")
}
