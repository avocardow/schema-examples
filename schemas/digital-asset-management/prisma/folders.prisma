// folders: Hierarchical directory structure for organizing assets within a workspace.
// See README.md for full design rationale.

model Folder {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  parentId    String?  @map("parent_id")
  name        String
  path        String
  depth       Int      @default(0)
  description String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderParent", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]  @relation("FolderParent")
  assets      Asset[]   @relation("AssetFolder")

  @@unique([workspaceId, path])
  @@unique([workspaceId, parentId, name])
  @@index([parentId])
  @@index([workspaceId, depth])
  @@map("folders")
}
