// workspaces: Top-level organizational unit for digital asset storage and management.
// See README.md for full design rationale.

model Workspace {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  description      String?
  logoUrl          String?  @map("logo_url")
  storageLimitBytes BigInt? @map("storage_limit_bytes")
  storageUsedBytes BigInt   @default(0) @map("storage_used_bytes")
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  folders          Folder[]
  assets           Asset[]
  collections      Collection[]
  tags             Tag[]
  metadataSchemas  MetadataSchema[]
  licenses         License[]
  downloadPresets  DownloadPreset[]
  shareLinks       ShareLink[]
  assetActivities  AssetActivity[]

  @@map("workspaces")
}
