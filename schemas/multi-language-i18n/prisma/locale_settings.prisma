// locale_settings: Locale-specific formatting preferences (dates, numbers, currency).
// See README.md for full design rationale.

model LocaleSetting {
  id                String   @id @default(uuid())
  localeId          String   @unique @map("locale_id")
  dateFormat        String?  @map("date_format") // e.g., "YYYY-MM-DD", "DD/MM/YYYY".
  timeFormat        String?  @map("time_format") // e.g., "HH:mm", "h:mm a".
  numberFormat      String?  @map("number_format") // e.g., "1,234.56" vs "1.234,56".
  currencyCode      String?  @map("currency_code") // ISO 4217 (e.g., "USD", "EUR").
  currencySymbol    String?  @map("currency_symbol") // e.g., "$", "€".
  firstDayOfWeek    Int      @default(1) @map("first_day_of_week") // 0 = Sunday, 1 = Monday.
  measurementSystem String?  @map("measurement_system") // "metric" or "imperial".
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  locale            Locale   @relation(fields: [localeId], references: [id], onDelete: Cascade)

  @@map("locale_settings")
}
