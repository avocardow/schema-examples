// locales: Supported languages/regions with display metadata and plural rules.
// See README.md for full design rationale.

enum TextDirection {
  ltr
  rtl
}

model Locale {
  id            String        @id @default(uuid())
  code          String        @unique // BCP-47 language tag (e.g., "en-US", "ja").
  name          String // English display name (e.g., "Japanese").
  nativeName    String?       @map("native_name") // Name in the locale's own script (e.g., "日本語").
  textDirection TextDirection @default(ltr) @map("text_direction")
  script        String? // ISO 15924 script code (e.g., "Latn", "Jpan").
  pluralRule    String?       @map("plural_rule") // CLDR plural rule identifier.
  pluralForms   Int           @default(2) @map("plural_forms") // Number of plural categories.
  isDefault     Boolean       @default(false) @map("is_default")
  isEnabled     Boolean       @default(true) @map("is_enabled")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @map("updated_at")

  // Reverse relations
  fallbacksFrom             LocaleFallback[]           @relation("LocaleFallbackFrom")
  fallbacksTo               LocaleFallback[]           @relation("LocaleFallbackTo")
  settings                  LocaleSetting?
  translationValues         TranslationValue[]
  contentTranslations       ContentTranslation[]
  translationGroups         TranslationGroup[]
  tmEntriesAsSource         TranslationMemoryEntry[]   @relation("TMSource")
  tmEntriesAsTarget         TranslationMemoryEntry[]   @relation("TMTarget")
  glossaryTerms             GlossaryTerm[]
  glossaryTermTranslations  GlossaryTermTranslation[]
  importExportJobs          ImportExportJob[]

  @@index([isEnabled])
  @@map("locales")
}
