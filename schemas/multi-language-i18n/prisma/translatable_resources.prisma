// translatable_resources: Registry of entity types whose fields support content translation.
// See README.md for full design rationale.

model TranslatableResource {
  id                String   @id @default(uuid())
  resourceType      String   @unique @map("resource_type") // e.g., "product", "category", "page".
  displayName       String   @map("display_name") // Human-readable name for the resource type.
  translatableFields Json    @map("translatable_fields") // JSON array of field names that can be translated.
  description       String? // Explains what this resource represents.
  isEnabled         Boolean  @default(true) @map("is_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  // Reverse relations
  contentTranslations ContentTranslation[]
  translationGroups   TranslationGroup[]

  @@map("translatable_resources")
}
