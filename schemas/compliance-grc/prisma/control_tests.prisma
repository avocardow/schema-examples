// control_tests: Test executions validating control effectiveness.
// See README.md for full design rationale.

enum ControlTestResult {
  pass
  fail
  partial
  not_applicable
}

model ControlTest {
  id           String            @id @default(uuid())
  controlId    String            @map("control_id")
  testedBy     String?           @map("tested_by")
  testDate     DateTime          @map("test_date")
  result       ControlTestResult
  notes        String?
  nextTestDate DateTime?         @map("next_test_date")
  createdAt    DateTime          @default(now()) @map("created_at")

  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tester  User?   @relation("ControlTester", fields: [testedBy], references: [id], onDelete: SetNull)

  @@index([controlId])
  @@index([testedBy])
  @@index([result])
  @@index([testDate])
  @@map("control_tests")
}
