// moderator_assignments: Default routing of content to moderators.
// See README.md for full design rationale.

enum ModeratorAssignmentScope {
  community
  channel
  category
}

enum ModeratorAssignmentRole {
  moderator
  senior_moderator
  admin
}

model ModeratorAssignment {
  id          String                  @id @default(uuid())
  moderatorId String                  @map("moderator_id")
  scope       ModeratorAssignmentScope
  scopeId     String                  @map("scope_id")
  role        ModeratorAssignmentRole @default(moderator)
  isActive    Boolean                 @default(true) @map("is_active")
  assignedAt  DateTime                @default(now()) @map("assigned_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @default(now()) @map("updated_at")

  // Relations
  moderator User @relation(fields: [moderatorId], references: [id], onDelete: Cascade)

  @@unique([moderatorId, scope, scopeId])
  @@index([scope, scopeId])
  @@index([isActive])
  @@map("moderator_assignments")
}
