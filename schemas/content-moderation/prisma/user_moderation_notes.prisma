// user_moderation_notes: Internal moderator notes on user accounts.
// See README.md for full design rationale.

model UserModerationNote {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  authorId  String   @map("author_id")
  body      String                        // The note text. Internal-only, never shown to the user.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  // Relations
  user   User @relation("UserModerationNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  author User @relation("UserModerationNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([authorId])
  @@map("user_moderation_notes")
}
