// strikes: Accumulated violations with configurable expiry.
// See README.md for full design rationale.

enum StrikeSeverity {
  minor
  moderate
  severe
}

enum StrikeResolution {
  active
  expired
  appealed_overturned
}

model Strike {
  id                  String           @id @default(uuid())
  userId              String           @map("user_id")
  moderationActionId  String           @map("moderation_action_id")
  violationCategoryId String?          @map("violation_category_id")
  severity            StrikeSeverity   @default(moderate)
  issuedAt            DateTime         @default(now()) @map("issued_at")
  expiresAt           DateTime?        @map("expires_at")
  isActive            Boolean          @default(true) @map("is_active")
  resolution          StrikeResolution @default(active)
  createdAt           DateTime         @default(now()) @map("created_at")

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  moderationAction  ModerationAction   @relation(fields: [moderationActionId], references: [id], onDelete: Restrict)
  violationCategory ViolationCategory? @relation(fields: [violationCategoryId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@index([moderationActionId])
  @@index([violationCategoryId])
  @@index([expiresAt, isActive])
  @@index([resolution])
  @@map("strikes")
}
