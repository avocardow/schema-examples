// keyword_list_entries: Individual words/phrases in keyword lists.
// See README.md for full design rationale.

enum KeywordMatchType {
  exact
  contains
  regex
}

model KeywordListEntry {
  id              String           @id @default(uuid())
  listId          String           @map("list_id")
  value           String
  matchType       KeywordMatchType @default(exact) @map("match_type")
  isCaseSensitive Boolean          @default(false) @map("is_case_sensitive")
  addedBy         String           @map("added_by")
  createdAt       DateTime         @default(now()) @map("created_at")

  // Relations
  list        KeywordList @relation(fields: [listId], references: [id], onDelete: Cascade)
  addedByUser User        @relation(fields: [addedBy], references: [id], onDelete: Restrict)

  @@unique([listId, value, matchType])
  @@map("keyword_list_entries")
}
