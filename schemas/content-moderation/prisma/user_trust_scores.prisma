// user_trust_scores: User reputation tracking in the moderation system.
// See README.md for full design rationale.

enum TrustLevel {
  new
  basic
  member
  trusted
  veteran
}

model UserTrustScore {
  id                String     @id @default(uuid())
  userId            String     @unique @map("user_id")
  trustLevel        TrustLevel @default(new) @map("trust_level")
  trustScore        Decimal    @default(0.5) @map("trust_score")
  totalReportsFiled Int        @default(0) @map("total_reports_filed")
  reportsUpheld     Int        @default(0) @map("reports_upheld")
  reportsDismissed  Int        @default(0) @map("reports_dismissed")
  flagAccuracy      Decimal    @default(0.5) @map("flag_accuracy")
  contentViolations Int        @default(0) @map("content_violations")
  lastViolationAt   DateTime?  @map("last_violation_at")
  updatedAt         DateTime   @default(now()) @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trustLevel])
  @@index([trustScore])
  @@map("user_trust_scores")
}
