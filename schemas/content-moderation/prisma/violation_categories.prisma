// violation_categories: Hierarchical taxonomy of content violation types.
// See README.md for full design rationale.

enum ViolationSeverity {
  info
  low
  medium
  high
  critical
}

model ViolationCategory {
  id          String            @id @default(uuid())
  name        String            @unique // Machine-readable identifier (e.g., "hate_speech", "csam").
  displayName String            @map("display_name") // Human-readable label (e.g., "Hate Speech").
  description String? // Detailed explanation of what this category covers.
  parentId    String?           @map("parent_id") // Null = top-level category.

  // info = informational/advisory.
  // low = minor policy violation.
  // medium = standard violation.
  // high = serious violation requiring prompt action.
  // critical = illegal content, imminent harm — highest priority.
  severity    ViolationSeverity @default(medium) @map("severity")

  isActive    Boolean           @default(true) @map("is_active") // Soft-disable without deleting.
  sortOrder   Int               @default(0) @map("sort_order") // Display ordering within parent group.
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @default(now()) @map("updated_at")

  // Self-referencing hierarchy
  parent      ViolationCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    ViolationCategory[] @relation("CategoryHierarchy")

  // Reverse relations
  policies    ModerationPolicy[]
  actions     ModerationAction[]
  strikes     Strike[]
  templates   ResponseTemplate[]

  @@index([parentId])
  @@index([isActive, sortOrder])
  @@map("violation_categories")
}
