// notification_workflow_runs: Execution instances of a workflow.
// Each time a workflow is triggered by an event, a run is created to track execution state.
// See README.md for full design rationale and field documentation.

enum WorkflowRunStatus {
  pending
  running
  completed
  failed
  canceled
}

model NotificationWorkflowRun {
  id               String            @id @default(uuid())
  workflowId       String            @map("workflow_id")
  eventId          String            @map("event_id")

  // Execution lifecycle.
  status           WorkflowRunStatus @default(pending)

  // Which step the workflow is currently on (or last completed).
  // Useful for debugging: "this run failed at step 3 of 5."
  currentStepOrder Int?              @map("current_step_order")

  // Error details if the run failed.
  errorMessage     String?           @map("error_message") // Human-readable description of what went wrong.
  errorStepId      String?           @map("error_step_id") // Which step caused the failure.

  startedAt        DateTime?         @map("started_at")
  completedAt      DateTime?         @map("completed_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")

  workflow         NotificationWorkflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  event            NotificationEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  errorStep        NotificationWorkflowStep? @relation(fields: [errorStepId], references: [id], onDelete: SetNull)

  @@index([workflowId, status])
  @@index([eventId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("notification_workflow_runs")
}
