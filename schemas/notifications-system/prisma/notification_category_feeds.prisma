// notification_category_feeds: Many-to-many join between categories and feeds.
// See README.md for full design rationale and field documentation.

model NotificationCategoryFeed {
  categoryId String @map("category_id")
  feedId     String @map("feed_id")

  category NotificationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  feed     NotificationFeed     @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@id([categoryId, feedId])
  @@index([feedId])
  @@map("notification_category_feeds")
}
