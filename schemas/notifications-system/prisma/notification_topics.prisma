// notification_topics: Named pub/sub groups for fan-out delivery.
// When a notification targets a topic, it fans out to all subscribers of that topic.
// See README.md for full design rationale and field documentation.

model NotificationTopic {
  id          String   @id @default(uuid())
  name        String // Display name (e.g., "Project Updates", "Marketing Newsletter").
  slug        String   @unique // Identifier used in code and API (e.g., "project_updates", "marketing").
  description String? // Explain what subscribing to this topic means.
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Reverse relations
  subscriptions NotificationSubscription[]

  @@map("notification_topics")
}
