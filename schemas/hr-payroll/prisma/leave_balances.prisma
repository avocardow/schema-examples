// leave_balances: Tracks employee leave accrual, usage, and carry-over per policy and year.
// See README.md for full design rationale.

model LeaveBalance {
  id            String      @id @default(uuid())
  employeeId    String      @map("employee_id")
  leavePolicyId String      @map("leave_policy_id")
  balance       Decimal     @default(0)
  accrued       Decimal     @default(0)
  used          Decimal     @default(0)
  carriedOver   Decimal     @default(0) @map("carried_over")
  year          Int
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @default(now()) @map("updated_at")

  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leavePolicy   LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leavePolicyId, year])
  @@index([leavePolicyId])
  @@map("leave_balances")
}
