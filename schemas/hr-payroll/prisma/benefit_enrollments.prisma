// benefit_enrollments: Employee enrollment in benefit plans with coverage and contribution details.
// See README.md for full design rationale.

enum CoverageLevel {
  employee_only
  employee_spouse
  employee_children
  family
}

enum BenefitEnrollmentStatus {
  active
  pending
  terminated
  waived
}

model BenefitEnrollment {
  id                    String                   @id @default(uuid())
  employeeId            String                   @map("employee_id")
  benefitPlanId         String                   @map("benefit_plan_id")
  coverageLevel         CoverageLevel            @default(employee_only) @map("coverage_level")
  employeeContribution  Int                      @default(0) @map("employee_contribution")
  employerContribution  Int                      @default(0) @map("employer_contribution")
  currency              String                   @default("USD")
  effectiveDate         String                   @map("effective_date")
  endDate               String?                  @map("end_date")
  status                BenefitEnrollmentStatus  @default(pending)
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @default(now()) @map("updated_at")

  employee              Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  benefitPlan           BenefitPlan              @relation(fields: [benefitPlanId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([benefitPlanId])
  @@index([status])
  @@index([effectiveDate])
  @@map("benefit_enrollments")
}
