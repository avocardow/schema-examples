// contacts: People your business interacts with, tracked through their lifecycle.
// See README.md for full design rationale and field documentation.

enum ContactLifecycleStage {
  subscriber
  lead
  qualified
  opportunity
  customer
  evangelist
  other
}

enum ContactSource {
  web
  referral
  organic
  paid
  social
  event
  cold_outreach
  other
}

model Contact {
  id             String                @id @default(uuid())
  firstName      String                @map("first_name")
  lastName       String                @map("last_name")
  email          String                @unique
  phone          String?
  title          String?
  lifecycleStage ContactLifecycleStage @default(lead) @map("lifecycle_stage")
  source         ContactSource?
  ownerId        String?               @map("owner_id")
  avatarUrl      String?               @map("avatar_url")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @default(now()) @map("updated_at")

  owner User? @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contactCompanies ContactCompany[]
  dealContacts     DealContact[]
  activities       Activity[]     @relation("ActivityContact")
  tasks            Task[]         @relation("TaskContact")
  notes            Note[]         @relation("NoteContact")
  contactTags      ContactTag[]
  dealsAsPrimary   Deal[]         @relation("DealPrimaryContact")
  leads            Lead[]         @relation("ConvertedContact")

  @@index([ownerId])
  @@index([lifecycleStage])
  @@map("contacts")
}
