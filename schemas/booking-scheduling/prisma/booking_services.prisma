// booking_services: Snapshot of services and addons included in a booking, preserving pricing at time of booking.
// See README.md for full design rationale and field documentation.

model BookingService {
  id          String   @id @default(uuid())
  bookingId   String   @map("booking_id")
  serviceId   String?  @map("service_id")
  addonId     String?  @map("addon_id")
  serviceName String   @map("service_name")
  duration    Int
  price       Decimal?
  currency    String?
  isPrimary   Boolean  @default(true) @map("is_primary")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  addon   ServiceAddon? @relation(fields: [addonId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([serviceId])
  @@map("booking_services")
}
