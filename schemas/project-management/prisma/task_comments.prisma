// task_comments: Threaded discussion entries attached to tasks.
// See README.md for full design rationale and field documentation.

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String?  @map("user_id")
  parentId  String?  @map("parent_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  task   Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User?        @relation("TaskCommentAuthor", fields: [userId], references: [id], onDelete: SetNull)
  parent TaskComment? @relation("CommentReply", fields: [parentId], references: [id], onDelete: Cascade)

  replies TaskComment[] @relation("CommentReply")

  @@index([taskId])
  @@index([parentId])
  @@index([userId])
  @@map("task_comments")
}
